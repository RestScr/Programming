<Window x:Name="window" x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:View"
        xmlns:vm="clr-namespace:View.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="547">
    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="371*"/>
            <RowDefinition Height="33*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="273*"/>
            <ColumnDefinition Width="274*"/>
        </Grid.ColumnDefinitions>
        <GroupBox Grid.Column="0" 
                  Header="Edit Contact">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="122*"/>
                </Grid.RowDefinitions>
                <Label Content="Name:" 
                       Grid.Row="0"
                       Margin="3"/>
                <TextBox Grid.Row="1"
                         Margin="3"
                         Text="{Binding SelectedContact.Name, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Phone Number:"
                       Grid.Row="2"
                       Margin="3"/>
                <TextBox Grid.Row="3"
                         Text="{Binding SelectedContact.PhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Email:"
                       Grid.Row="4"
                       Margin="3"/>
                <TextBox Grid.Row="5"
                         Margin="3"
                         Text="{Binding SelectedContact.Email, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="Read Contact"
                  Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="187*"/>
                    <RowDefinition Height="32*"/>
                </Grid.RowDefinitions>
                <Label Content="Name:"
                       Grid.Row="0"
                       Margin="3"/>
                <Label Content="{Binding SelectedContact.Name}"
                       Grid.Row="1"
                       Margin="3"/>
                <Label Content="Phone Number:"
                       Grid.Row="2"
                       Margin="3"/>
                <Label Content="{Binding SelectedContact.PhoneNumber}"
                       Grid.Row="3"
                       Margin="3"/>
                <Label Content="Email:"
                       Grid.Row="4"
                       Margin="3"/>
                <Label Content="{Binding SelectedContact.Email}"
                       Grid.Row="5"
                       Margin="3"/>


            </Grid>
        </GroupBox>
        <StackPanel Orientation="Horizontal"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Grid.Column="1"
                    HorizontalAlignment="Right">
            <Button Width="75" 
                    Height="25"
                    Content="Save"
                    Margin="3"
                    Command="{Binding SaveOperation}"/>
            <Button Width="75"
                    Height="25"
                    Content="Load"
                    Margin="3"
                    Command="{Binding LoadOperation}"/>
        </StackPanel>
    </Grid>
</Window>
