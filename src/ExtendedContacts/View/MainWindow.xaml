<Window x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:View"
        xmlns:vm="clr-namespace:View.ViewModel"
        xmlns:databinding="clr-namespace:View.ViewModel.Converters"
        mc:Ignorable="d"
        Title="Contacts" 
        Height="450" 
        Width="800" 
        Icon="/assets/ContactsApp_96x96.ico">

    <!-- Добавление контекста данных из MainVM -->
    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Добавление конвертера -->
        <databinding:ReverseBoolConverter 
            x:Key="ReverseBoolConverter"/>
    </Window.Resources>

    <!-- Главный интерфейс окна -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition 
                Width="100*"
                />
            <ColumnDefinition 
                Width="154*"
                />
        </Grid.ColumnDefinitions>

        <GridSplitter 
            HorizontalAlignment="Left" 
            Height="450" 
            VerticalAlignment="Top" 
            Width="3" Grid.Column="1"/>
        <Border 
            Background="#F8F8F8"
            Grid.Column="0"/>

        <!-- Левая колонка -->
        <Grid Margin="8,8,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="33*"/>
                <RowDefinition Height="364*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>
            <Grid
                Grid.Row="0"
                Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="41"/>
                    <ColumnDefinition Width="258*"/>
                </Grid.ColumnDefinitions>
                <Label 
                    Content="Find:"
                    Margin="3,3,3,3"
                    Grid.Column="0"
                    />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="3"/>
            </Grid>

            <!-- Список контактов -->
            <ListBox 
                Grid.Column="0"
                Grid.Row="1"
                ItemsSource="{Binding ContactList}"
                SelectedItem="{Binding SelectedContact}"
                DisplayMemberPath="Name"
                Margin="3"
                />

            <!-- Набор кнопок добавления/редактирования/удаления-->
            <Grid
                Grid.Row="2"
                Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Height="25"
                    Margin="3"
                    Content="Add"
                    Command="{Binding AddCommand}"
                    />
                <Button
                    Grid.Column="1"
                    Height="25"
                    Margin="3"
                    Content="Edit"
                    Command="{Binding EditCommand}"
                    CommandParameter="{Binding SelectedContact}"
                    />
                <Button
                    Grid.Column="2"
                    Height="25"
                    Margin="3"
                    Content="Remove"
                    Command="{Binding RemoveCommand}"
                    CommandParameter="{Binding SelectedContact}"
                    />
            </Grid>
        </Grid>
        <!-- Правая колонка -->
        <Grid 
            Grid.Column="1"
            Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="40"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Image
                Grid.RowSpan="4"
                Grid.Row="1"
                Grid.Column="0" 
                Margin="3,3,3,3" 
                Source="assets/photo_placeholder_100x100.png"
                />

            <!-- Ввод и отображение имени -->
            <Label
                Grid.Column="1"
                Grid.Row="0"
                Content="Name:"
                Margin="3,3,3,3"/>
            <TextBox
                Grid.Row="1"
                Grid.Column="1"
                Margin="3,3,3,3"
                Text="{Binding SelectedContact.TemporaryNameField}"
                IsReadOnly="{Binding EditMode, Converter={StaticResource ReverseBoolConverter}}"
                />

            <!-- Ввод и отображение номера телефона -->
            <Label
                Grid.Column="1"
                Grid.Row="2"
                Content="Phone Number:"
                Margin="3,3,3,3"/>
            <TextBox
                Grid.Row="3"
                Grid.Column="1"
                Margin="3,3,3,3"
                Text="{Binding SelectedContact.TemporaryPhoneNumberField}"
                IsReadOnly="{Binding EditMode, Converter={StaticResource ReverseBoolConverter}}"
                />

            <!-- Ввод и отображение электронной почты -->
            <Label
                Grid.Column="1"
                Grid.Row="4"
                Content="Email:"
                Margin="3,3,3,3"/>
            <TextBox
                Grid.Row="5"
                Grid.Column="1"
                Margin="3,3,3,3"
                Text="{Binding SelectedContact.TemporaryEmailField}"
                IsReadOnly="{Binding EditMode, Converter={StaticResource ReverseBoolConverter}}"
                />

            <!-- Кнопка подтверждения -->
            <StackPanel
                Grid.Row="7"
                Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Left" Width="81">
                <Button 
                    Content="Apply"
                    Grid.Column="1"
                    Grid.Row="7"
                    Height="25"
                    Width="75" 
                    Margin="3"
                    Command="{Binding ApplyCommand}" 
                    AutomationProperties.Name="ApplyButton"
                    />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
